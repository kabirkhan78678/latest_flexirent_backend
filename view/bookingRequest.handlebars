<html
  xmlns="http://www.w3.org/1999/xhtml"
  xmlns:v="urn:schemas-microsoft-com:vml"
  xmlns:o="urn:schemas-microsoft-com:office:office"
>

  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="x-apple-disable-message-reformatting" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>Booking Request</title>

    <style type="text/css">
      @import
      url("https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap");
      a,a[href],a:hover, a:link, a:visited { text-decoration: none!important;
      color: #0000EE; } .link { text-decoration: underline!important; } p,
      p:visited { font-size:15px; line-height:24px; font-family: 'Poppins',
      sans-serif; font-weight:300; text-decoration:none; color: #000000; } h1 {
      font-size:22px; line-height:24px; font-family: 'Poppins', sans-serif;
      font-weight:normal; text-decoration:none; color: #000000; } .ExternalClass
      p, .ExternalClass span, .ExternalClass font, .ExternalClass td
      {line-height: 100%;} .ExternalClass {width: 100%;}
    </style>
  </head>

  <body
    style="text-align: center; margin: 0; padding-top: 30px; padding-bottom: 10px; padding-left: 0; padding-right: 0; -webkit-text-size-adjust: 100%;background-color: #f2f4f6; color: #000000"
    align="center"
  >
    <div style="text-align: center;">
      <!-- Start container for logo -->
      <table
        align="center"
        style="text-align: center; vertical-align: top; width: 100%; max-width: 600px; background-color: #cce8ff66;"
        width="600"
      >
        <tbody>
          <tr>
            <td
              style="width: 596px; vertical-align: top; padding-left: 0; padding-right: 0; padding-top: 15px; padding-bottom: 15px;"
              width="596"
            >

              <!-- Your logo is here -->
              <img
                style="width: 180px; max-width: 180px; height: 85px; max-height: 85px; text-align: center; color: #ffffff; object-fit: contain;"
                alt="Logo"
                src="{{image_logo}}"
                align="center"
                width="180"
                height="85"
              />

            </td>
          </tr>
        </tbody>
      </table>
      <!-- End container for logo -->
      <!-- Start single column section -->
      <table
        align="center"
        style="text-align: center; vertical-align: top; width: 100%; max-width: 600px; background-color: #fff;"
        width="600"
      >
        <tbody>
          <tr>
            <td
              style="width: 596px; vertical-align: top; padding-left: 30px; padding-right: 30px; padding-top: 30px; padding-bottom: 40px;"
              width="596"
            >

              <h1
                style="font-size: 20px; line-height: 24px; font-weight: 600; font-family: 'Poppins', sans-serif; text-decoration: none; color: #000000;"
              >Booking Request</h1>
              <h6
                style="font-size: 16px; line-height: 24px; margin-bottom: 0px; font-weight: 600; font-family: 'Poppins', sans-serif; text-decoration: none; color: #000000; text-align: left;"
              >Hi {{name}},</h6>
              <p
                style="margin-top:10px;font-family: 'Poppins', sans-serif; text-align: left;font-weight:400;color: #919293;"
              >{{msg}}</p>

              <div
                style="background-color: #f8f8f8; padding: 15px; margin-top: 27px; border-radius: 10px;"
              >
                <table style="width:100% max-width:70%">
                  <tbody>
                    {{#if booked_person_name}}
                      <tr>
                        <td
                          style="font-family: 'Poppins', sans-serif; font-size: 16px; text-align:left; font-weight: 500;"
                        >User Name</td>
                        <td>:</td>
                        <td
                          style="font-family: 'Poppins', sans-serif; font-size: 16px; text-align:left; padding-left:15px;"
                        >
                          {{booked_person_name}}
                        </td>
                      </tr>
                    {{/if}}
                    <tr>
                      <td
                        style="font-family: 'Poppins', sans-serif; font-size: 16px; text-align:left; font-weight: 500;"
                      >Reservation ID</td>
                      <td>:</td>
                      <td
                        style="font-family: 'Poppins', sans-serif; font-size: 16px; text-align:left; padding-left:15px"
                      >{{reservation_id}}</td>
                    </tr>
                    <tr>
                      <td
                        style="font-family: 'Poppins', sans-serif; font-size: 16px; text-align:left; font-weight: 500;"
                      >Property</td>
                      <td>:</td>
                      <td
                        style="font-family: 'Poppins', sans-serif; font-size: 16px; text-align:left; padding-left:15px"
                      >{{Property}}</td>
                    </tr>
                    <tr>
                      <td
                        style="font-family: 'Poppins', sans-serif; font-size: 16px; text-align:left; font-weight: 500;"
                      >Check-In</td>
                      <td>:</td>
                      <td
                        style="font-family: 'Poppins', sans-serif; font-size: 16px; text-align:left; padding-left:15px"
                      >{{Check_In}}</td>
                    </tr>
                    <tr>
                      <td
                        style="font-family: 'Poppins', sans-serif; font-size: 16px; text-align:left; font-weight: 500;"
                      >Check-Out</td>
                      <td>:</td>
                      <td
                        style="font-family: 'Poppins', sans-serif; font-size: 16px; text-align:left; padding-left:15px"
                      >{{Check_Out}}</td>
                    </tr>
                    <tr>
                      <td
                        style="font-family: 'Poppins', sans-serif; font-size: 16px; text-align:left; font-weight: 500;"
                      >Guests</td>
                      <td>:</td>
                      <td
                        style="font-family: 'Poppins', sans-serif; font-size: 16px; text-align:left; padding-left:15px"
                      >{{Guests}}</td>
                    </tr>
                    <tr>
                      <td
                        style="font-family: 'Poppins', sans-serif; font-size: 16px; text-align:left; font-weight: 500;"
                      >Total Price</td>
                      <td>:</td>
                      <td
                        style="font-family: 'Poppins', sans-serif; font-size: 16px; text-align:left; padding-left:15px"
                      >{{total_price}}</td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <div style="padding-top: 40px; text-align: left;">
                <h4
                  style="margin-bottom: 10px; margin-top: 0px; font-family: 'Poppins', sans-serif;"
                >Cheers,</h4>
                <p
                  style="margin-top: 0px; font-weight: 500; font-family: 'Poppins', sans-serif;"
                >FlexsiRent Team</p>
              </div>
            </td>
          </tr>
        </tbody>
      </table>

      <!-- End single column section -->
      <!-- Start footer -->
      <table
        align="center"
        style="text-align: center; vertical-align: top; width: 100%; max-width: 600px; background-color: #071537;"
        width="600"
      >
        <tbody>
          <tr>
            <td
              style="width: 596px; vertical-align: top; padding-left: 30px; padding-right: 30px; padding-top: 30px; padding-bottom: 30px;"
              width="596"
            >

              <p
                style="margin-bottom:10px; margin-top: 0px; text-align:center; color:#fff; font-family: 'Poppins', sans-serif;"
              >Need More Help?</p>

            </td>
          </tr>
        </tbody>
      </table>
      <!-- End footer -->
    </div>

  </body>

</html>